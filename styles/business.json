{
  "version": 2,
  "title": "Business",
  "settings": {
    "color": {
      "palette": [
        { "slug": "primary", "color": "#1A73E8", "name": "Primary" },
        { "slug": "secondary", "color": "#2196F3", "name": "Secondary" },
        { "slug": "tertiary", "color": "#0D47A1", "name": "Tertiary" }
      ]
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)"
    }
  },
  "styles": {
    "color": {
      "background": "#F8FAFC",
      "text": "var(--wp--preset--color--neutral-900)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "lineHeight": "1.6"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "6px"
        },
        "shadow": "var(--wp--preset--shadow--sm)",
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "#ffffff"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "h2": {
        "typography": {
          "fontWeight": "700"
        }
      }
    },
    "blocks": {
      "core/quote": {
        "border": {
          "color": "var(--wp--preset--color--primary)"
        }
      },
      "core/separator": {
        "color": {
          "text": "var(--wp--preset--color--neutral-300)"
        }
      }
    }
  }
}