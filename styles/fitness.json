            "top": "0.875rem",
            "right": "2rem",
            "bottom": "0.875rem",
            "left": "2rem"
          }
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--neutral-100)"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--secondary)"
          }
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--neutral-900)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--neutral-700)"
          }
        }
      },
      "h1": {
        "typography": {
          "fontWeight": "800",
          "lineHeight": "1.1",
          "letterSpacing": "-0.02em"
        },
        "color": {
          "text": "var(--wp--preset--color--neutral-900)"
        }
      },
      "h2": {
        "typography": {
          "fontWeight": "700",
          "lineHeight": "1.2"
        },
        "color": {
          "text": "var(--wp--preset--color--neutral-900)"
        }
      },
      "h3": {
        "typography": {
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      }
    }
